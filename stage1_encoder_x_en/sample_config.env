# Copy this file to stage1_encoder_x_en/config.env and edit paths.

# GPUs visible to torchrun. Example: "1,2,3" leaves GPU0 free.
CUDA_VISIBLE_DEVICES_VALUE="1,2,3"
NPROC_PER_NODE=3

# Local base models. For paper-style base, use Meta-Llama-3-8B, not Instruct.
MT_PATH="model/nllb-200-1.3B"
LLM_PATH="model/Meta-Llama-3-8B"

# Data construction mode:
# - parallel: SOURCE_FILE + ENGLISH_FILE
# - json: INPUT_FILE with source/target fields
DATA_MODE="parallel"
INPUT_FILE=""
SOURCE_FILE="data/raw/zh.txt"
ENGLISH_FILE="data/raw/en.txt"
SRC_LANG="zho_Hans"
PROMPT="Translate into English:"
TRAIN_FILE="data/stage1_encoder_x_en/zh_en.jsonl"

# Output
OUTPUT_DIR="outputs/stage1_encoder_x_en_zh"

# Training
PER_DEVICE_BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=5
LEARNING_RATE="2e-5"
WEIGHT_DECAY="0.01"
NUM_EPOCHS=3
WARMUP_RATIO="0.03"
MAX_SRC_LEN=256
MAX_TGT_LEN=256
MAX_PROMPT_LEN=128
LOGGING_STEPS=10
SAVE_STEPS=500
MAX_STEPS=0
SEED=42
BF16=true
REINIT_MAPPING=true
RESUME_MAPPING=""

# Inference
INFER_INPUT_FILE="data/eval/zh.txt"
INFER_OUTPUT_FILE="outputs/stage1_encoder_x_en_zh/generated.en.txt"
BASE_MODEL="outputs/stage1_encoder_x_en_zh/checkpoint-final"
MAX_NEW_TOKENS=128
INFER_BATCH_SIZE=16
